SECRET_KEY=dev-secret-key-change-in-production
DATABASE_URL=sqlite:///youtube_lite.db
HOST=0.0.0.0
PORT=5000
DEBUG=true

# Optional convenience IPs for local hosting examples.
LAN_IP=192.168.1.50
VPN_IP=100.64.0.5

# Preferred: explicit frontend origin allowlist for localhost, LAN, and VPN access.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.50:5173,http://100.64.0.5:5173

# Simplest development fallback for LAN/VPN testing.
CORS_ALLOW_ALL_DEV=true

# Session cookies stay same-site in LAN HTTP mode when frontend and backend use
# the same http://<LAN_IP> host.
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false

# Optional: serve frontend/dist from Flask after npm run build.
SERVE_FRONTEND_BUILD=false

# Optional: AI quiz generation from uploaded lesson media.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_QUIZ_MODEL=gpt-4o-mini
QUIZ_AI_DEFAULT_QUESTION_COUNT=10
QUIZ_AI_MIN_TRANSCRIPT_CHARS=30
QUIZ_AI_MAX_TRANSCRIPT_CHARS=12000
QUIZ_AI_INCLUDE_VIDEO_FRAMES=true
QUIZ_AI_FRAME_SAMPLE_COUNT=4
QUIZ_AI_FRAME_WIDTH=768
QUIZ_AI_AUTO_GENERATE_ON_UPLOAD=false
QUIZ_AI_AUTO_GENERATE_QUESTION_COUNT=10
QUIZ_AI_CHUNK_SECONDS=600
QUIZ_AI_AUDIO_BITRATE_KBPS=64
QUIZ_AI_FFMPEG_BINARY=ffmpeg

# Production/App Platform notes:
# DEBUG=false
# PORT=8080
# SERVE_FRONTEND_BUILD=true
# CORS_ALLOW_ALL_DEV=false
# SESSION_COOKIE_SECURE=true
# DATABASE_URL=${howtoob-db.DATABASE_URL}
# DB_STARTUP_RETRIES=10
# DB_STARTUP_RETRY_SECONDS=3
# OPENAI_API_KEY should be set as a secret in DigitalOcean, not committed.
