# Direct frontend-to-backend calls over the LAN.
VITE_API_BASE_URL=http://192.168.1.50:5000

# Or direct calls over a private VPN overlay.
# VITE_API_BASE_URL=http://100.64.0.5:5000

# Optional: keep the Vite proxy target explicit when VITE_API_BASE_URL is unset.
VITE_BACKEND_PROXY_TARGET=http://localhost:5000

# DigitalOcean single-service Docker deployment serves the built frontend from Flask,
# so VITE_API_BASE_URL should usually be left empty there.
